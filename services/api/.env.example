# Comma-separated origins for browser clients (Next.js on Vercel + local)
API_CORS_ORIGINS=http://localhost:3000

# Phase 11–12: Trusted Host (để trống = tắt). Production: host Render + 127.0.0.1,localhost (Docker HEALTHCHECK nội bộ).
# API_TRUSTED_HOSTS=bitlysis-api-staging.onrender.com,127.0.0.1,localhost

# Staging URL ví dụ (ghi vào docs/DEPLOY-RENDER-VERCEL.md sau khi deploy)
# BITLYSIS_STAGING_API_URL=https://bitlysis-api-staging.onrender.com

# Lưu file upload (đường dẫn tương đối khi chạy từ services/api)
UPLOAD_DIR=./data/uploads
# ~50 MiB
MAX_UPLOAD_BYTES=52428800

# Profiling sample cap per upload (rows read for stats; 50–500_000)
PROFILING_MAX_ROWS=10000

# Retention (ADR 0003): sweep chạy mỗi RETENTION_SWEEP_INTERVAL_SECONDS
RETENTION_ENABLED=true
RETENTION_HOURS=168
RETENTION_SWEEP_INTERVAL_SECONDS=3600

# Rate limit POST /v1/upload (mỗi IP, sliding window)
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_MAX_REQUESTS=60
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60

# Phase 5: Rscript (Cronbach / EFA / PLS-SEM)
# R_SUBPROCESS_TIMEOUT_SECONDS=180
# R_PACKAGE_ROOT=../packages/r-pipeline
# BITLYSIS_RSCRIPT_PATH=C:/Program Files/R/R-4.4.2/bin/Rscript.exe

# Phase 7 — OpenRouter (ADR 0004); key chỉ env, không commit
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_ENABLED=true
# LLM_TIMEOUT_SECONDS=45
# LLM_MAX_HYPOTHESES=10
# APP_ENVIRONMENT=development
# LLM_LOG_PROMPTS=false

# Phase 8 — export ZIP
# EXPORT_ZIP_HEAVY_THRESHOLD_BYTES=5242880
# EXPORT_MAX_ZIP_BYTES=104857600
# EXPORT_DATA_MAX_ROWS=100000
# EXPORT_INCLUDE_PLOTLY=true
# EXPORT_DOCX_TEMPLATE_PATH=
