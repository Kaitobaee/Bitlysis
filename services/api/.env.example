# Comma-separated origins for browser clients (Next.js on Vercel + local)
API_CORS_ORIGINS=http://localhost:3000

# Phase 11â€“12: Trusted Host (Ä‘á»ƒ trá»‘ng = táº¯t). Production: host Render + 127.0.0.1,localhost (Docker HEALTHCHECK ná»™i bá»™).
# API_TRUSTED_HOSTS=bitlysis-api-staging.onrender.com,127.0.0.1,localhost

# Staging URL vÃ­ dá»¥ (ghi vÃ o docs/DEPLOY-RENDER-VERCEL.md sau khi deploy)
# BITLYSIS_STAGING_API_URL=https://bitlysis-api-staging.onrender.com

# LÆ°u file upload (Ä‘Æ°á»ng dáº«n tÆ°Æ¡ng Ä‘á»‘i khi cháº¡y tá»« services/api)
UPLOAD_DIR=./data/uploads
# ~50 MiB
MAX_UPLOAD_BYTES=52428800

# Profiling sample cap per upload (rows read for stats; 50â€“500_000)
PROFILING_MAX_ROWS=10000

# Retention (ADR 0003): sweep cháº¡y má»—i RETENTION_SWEEP_INTERVAL_SECONDS
RETENTION_ENABLED=true
RETENTION_HOURS=168
RETENTION_SWEEP_INTERVAL_SECONDS=3600

# Rate limit POST /v1/upload (má»—i IP, sliding window)
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_MAX_REQUESTS=60
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60

# Phase 5: Rscript (Cronbach / EFA / PLS-SEM)
# R_SUBPROCESS_TIMEOUT_SECONDS=180
# R_PACKAGE_ROOT=../packages/r-pipeline
# BITLYSIS_RSCRIPT_PATH=C:/Program Files/R/R-4.4.2/bin/Rscript.exe

# Phase 7 â€” OpenRouter (ADR 0004); key chá»‰ env, khÃ´ng commit
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Alternative direct OpenAI provider (use this if you do not use OpenRouter)
