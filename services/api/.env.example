# Comma-separated origins for browser clients (Next.js on Vercel + local)
API_CORS_ORIGINS=http://localhost:3000

# Lưu file upload (đường dẫn tương đối khi chạy từ services/api)
UPLOAD_DIR=./data/uploads
# ~50 MiB
MAX_UPLOAD_BYTES=52428800

# Profiling sample cap per upload (rows read for stats; 50–500_000)
PROFILING_MAX_ROWS=10000

# Retention (ADR 0003): sweep chạy mỗi RETENTION_SWEEP_INTERVAL_SECONDS
RETENTION_ENABLED=true
RETENTION_HOURS=168
RETENTION_SWEEP_INTERVAL_SECONDS=3600

# Rate limit POST /v1/upload (mỗi IP, sliding window)
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_MAX_REQUESTS=60
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60

# Later: OPENROUTER_API_KEY=...
